{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "compose-claude": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "../design/libs/ui-symbol/src/assets",
                "output": "./assets/lib-ui-symbol"
              },
              {
                "glob": "**/*",
                "input": "../design/libs/ui-theme/assets",
                "output": "./assets/lib-ui-theme"
              }
            ],
            "styles": [
              "src/styles.scss",
              "../design/libs/ui-theme/assets/style/theme.scss",
              "../design/libs/ui-theme/assets/desktop_variables.css"
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["../design/libs"]
            }
          },
          "configurations": {
            "development": {
              "optimization": false,
              "sourceMap": true
            },
            "production": {
              "optimization": true,
              "sourceMap": false,
              "outputHashing": "all",
              "namedChunks": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4200
          },
          "configurations": {
            "development": {
              "buildTarget": "compose-claude:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
